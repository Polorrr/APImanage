# AIManage 环境变量配置

# 数据库配置
DB_NAME=llm_cost
DB_USER=aimanage
DB_PASSWORD=aimanage123
DB_HOST=localhost
DB_PORT=3306

# Django 密钥（生产环境请修改）
DJANGO_SECRET_KEY=your-secret-key-here

# 调试模式（生产环境设为 False）
DEBUG=True

# 允许的主机（生产环境设为你的域名）
ALLOWED_HOSTS=localhost,127.0.0.1

# 加密密钥（用于 API Key 加密）
ENCRYPTION_KEY=your-encryption-key-here
